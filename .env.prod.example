# ══════════════════════════════════════════════════════════════════════════════
#  PRODUCCIÓN — copiá este archivo a `.env` en el servidor y completá los valores.
#  NUNCA subas el `.env` real al repo.
#  Generá los secrets con:  openssl rand -base64 32
# ══════════════════════════════════════════════════════════════════════════════

# ─── Base de datos (Postgres) ────────────────────────────────────────────────
# La MISMA contraseña debe ir en POSTGRES_PASSWORD y dentro de DATABASE_URL.
POSTGRES_USER=pizzaapp
POSTGRES_PASSWORD=CAMBIAR_password_fuerte_db
POSTGRES_DB=pizzaapp
DATABASE_URL=postgresql://pizzaapp:CAMBIAR_password_fuerte_db@postgres:5432/pizzaapp?schema=public

# ─── Redis ───────────────────────────────────────────────────────────────────
# La MISMA contraseña en REDIS_PASSWORD y dentro de REDIS_URL.
REDIS_PASSWORD=CAMBIAR_password_fuerte_redis
REDIS_URL=redis://:CAMBIAR_password_fuerte_redis@redis:6379

# ─── Auth.js / NextAuth ──────────────────────────────────────────────────────
AUTH_SECRET=CAMBIAR_secret_de_32+_chars
NEXTAUTH_URL=https://pizzacambalache.com.ar

# ─── Login social (opcional; si quedan vacíos, no aparece el botón) ──────────
# Copiá estos valores de tu apps/web/.env local (los que ya usás en desarrollo).
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_FACEBOOK_ID=
AUTH_FACEBOOK_SECRET=

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://pizzacambalache.com.ar

# ─── Mercado Pago (dejá vacío si todavía no lo usás) ─────────────────────────
MERCADOPAGO_ACCESS_TOKEN=
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=

# ─── WhatsApp Business Cloud API ─────────────────────────────────────────────
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=b716fc81756568b1130255946bc8fc3b
WHATSAPP_BUSINESS_ACCOUNT_ID=

# ─── Email / SMTP ────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Pizzería Cambalache <noreply@pizzacambalache.com.ar>

# ─── JWT (tokens de WhatsApp) ────────────────────────────────────────────────
JWT_SECRET=CAMBIAR_otro_secret

# ─── QZ Tray (firma de impresión) ────────────────────────────────────────────
# Certificado (público) y clave privada, en base64 de una sola línea. Se generan
# con openssl y se cargan en el server. Con el certificado importado en QZ Tray,
# deja de pedir "Allow" en cada impresión.
QZ_CERTIFICATE_B64=
QZ_PRIVATE_KEY_B64=
