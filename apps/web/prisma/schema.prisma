generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CUSTOMER
  ADMIN
  MOSTRADOR
}

enum OrderStatus {
  PENDIENTE_PAGO
  RECIBIDO
  CONFIRMADO
  PREPARANDO
  EN_HORNO
  LISTO
  EN_REPARTO
  ENTREGADO
  CANCELADO
}

enum PaymentMethod {
  MERCADO_PAGO
  EFECTIVO
  MIXTO
  TRANSFERENCIA
  // Pago con QR o tarjeta (débito/crédito). Cuenta como "virtual".
  TARJETA
  // Paga al retirar/recibir; el tipo real (efectivo/transferencia/mixto) se
  // define al registrar el cobro.
  A_DEFINIR
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum DeliveryType {
  DELIVERY
  PICKUP
}

// ─── Auth.js Models ───────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String?   @unique
  phone         String?   @unique
  name          String?
  password      String?
  role          Role      @default(CUSTOMER)
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  addresses     Address[]
  orders        Order[]
  cart          Cart?
  notifications Notification[]
  auditLogs     AuditLog[]

  @@index([email])
  @@index([phone])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Address ──────────────────────────────────────────────────────────────────

model Address {
  id         String   @id @default(cuid())
  userId     String
  street     String
  number     String
  apartment  String?
  city       String
  state      String
  zipCode    String?
  reference  String?
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]

  @@index([userId])
}

// ─── Catalog ──────────────────────────────────────────────────────────────────

model Category {
  id          String    @id @default(cuid())
  name        String    @unique
  slug        String    @unique
  description String?
  icon        String?
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  products Product[]
}

model Product {
  id          String   @id @default(cuid())
  name        String
  description String?
  price       Decimal  @db.Decimal(10, 2)
  image       String?
  categoryId  String
  stock       Int      @default(0)
  available   Boolean  @default(true)
  // Precios por tamaño para pizzas (null = no se ofrece en ese tamaño).
  priceSmall  Decimal? @db.Decimal(10, 2)
  priceMedium Decimal? @db.Decimal(10, 2)
  priceLarge  Decimal? @db.Decimal(10, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category       Category        @relation(fields: [categoryId], references: [id])
  cartItems      CartItem[]
  orderItems     OrderItem[]
  promotionItems PromotionItem[]
  stockMovements StockMovement[]

  @@index([categoryId])
  @@index([available])
  @@index([name])
}

// ─── Stock ────────────────────────────────────────────────────────────────────

enum StockMovementKind {
  ENTRADA // ingreso de mercadería (suma stock)
  SALIDA  // merma/ajuste negativo (resta stock)
}

model StockMovement {
  id          String            @id @default(cuid())
  productId   String
  kind        StockMovementKind
  quantity    Int
  note        String?
  createdById String?
  createdAt   DateTime          @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([kind])
  @@index([createdAt])
}

// Retiro del "dinero a favor" generado por la venta de postres. NO impacta en
// Finanzas: solo descuenta del disponible a favor de postres. El egreso real (si
// corresponde) se carga a mano en Finanzas, porque a veces el retiro no es dinero
// (p. ej. se cambia por mercadería).
model PostreWithdrawal {
  id          String   @id @default(cuid())
  amount      Decimal  @db.Decimal(10, 2)
  reason      String?
  createdById String?
  createdAt   DateTime @default(now())

  @@index([createdAt])
}

// ─── Promotions ───────────────────────────────────────────────────────────────

model Promotion {
  id               String    @id @default(cuid())
  name             String
  description      String?
  promotionalPrice Decimal   @db.Decimal(10, 2)
  image            String?
  available        Boolean   @default(true)
  startDate        DateTime?
  endDate          DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  items      PromotionItem[]
  cartItems  CartItem[]
  orderItems OrderItem[]

  @@index([available])
  @@index([startDate, endDate])
}

model PromotionItem {
  id          String @id @default(cuid())
  promotionId String
  productId   String
  quantity    Int    @default(1)

  promotion Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [productId], references: [id])

  @@unique([promotionId, productId])
  @@index([promotionId])
}

// ─── Cart ─────────────────────────────────────────────────────────────────────

model Cart {
  id        String     @id @default(cuid())
  userId    String     @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CartItem[]
}

model CartItem {
  id          String   @id @default(cuid())
  cartId      String
  productId   String?
  promotionId String?
  quantity    Int
  unitPrice   Decimal  @db.Decimal(10, 2)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  cart      Cart       @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product   Product?   @relation(fields: [productId], references: [id])
  promotion Promotion? @relation(fields: [promotionId], references: [id])

  @@index([cartId])
}

// ─── Orders ───────────────────────────────────────────────────────────────────

model Order {
  id             String        @id @default(cuid())
  orderNumber    String        @unique
  userId         String
  addressId      String?
  status         OrderStatus   @default(RECIBIDO)
  deliveryType   DeliveryType  @default(DELIVERY)
  paymentMethod  PaymentMethod
  subtotal       Decimal       @db.Decimal(10, 2)
  deliveryFee    Decimal       @db.Decimal(10, 2) @default(0)
  // Descuento aplicado al pedido (mostrador). total = subtotal + envío − descuento.
  discount       Decimal       @db.Decimal(10, 2) @default(0)
  total          Decimal       @db.Decimal(10, 2)
  // Sólo para paymentMethod = MIXTO: cuánto paga en efectivo y cuánto por transferencia.
  cashAmount     Decimal?      @db.Decimal(10, 2)
  transferAmount Decimal?      @db.Decimal(10, 2)
  notes          String?
  phone          String?
  whatsappToken  String?
  estimatedTime  Int?
  deliveryEmployeeId String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  user             User       @relation(fields: [userId], references: [id])
  address          Address?   @relation(fields: [addressId], references: [id])
  deliveryEmployee Employee?  @relation("OrderDeliveryEmployee", fields: [deliveryEmployeeId], references: [id])
  items            OrderItem[]
  payment          Payment?

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([orderNumber])
  @@index([deliveryEmployeeId])
}

model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  productId   String?
  promotionId String?
  quantity    Int
  unitPrice   Decimal @db.Decimal(10, 2)
  subtotal    Decimal @db.Decimal(10, 2)
  notes       String?

  order     Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product?   @relation(fields: [productId], references: [id])
  promotion Promotion? @relation(fields: [promotionId], references: [id])

  @@index([orderId])
}

// ─── Payments ─────────────────────────────────────────────────────────────────

model Payment {
  id                  String        @id @default(cuid())
  orderId             String        @unique
  method              PaymentMethod
  status              PaymentStatus @default(PENDING)
  amount              Decimal       @db.Decimal(10, 2)
  mpPaymentId         String?
  mpPreferenceId      String?
  mpExternalReference String?
  mpStatus            String?
  mpStatusDetail      String?
  paidAt              DateTime?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([mpPaymentId])
}

// ─── Settings ─────────────────────────────────────────────────────────────────

model ShipmentZone {
  id        String   @id @default(cuid())
  name      String
  radiusKm  Float
  available Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  deliveryFees DeliveryFee[]
}

model DeliveryFee {
  id             String        @id @default(cuid())
  shipmentZoneId String?
  name           String
  fee            Decimal       @db.Decimal(10, 2)
  minOrderAmount Decimal?      @db.Decimal(10, 2)
  isDefault      Boolean       @default(false)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  zone ShipmentZone? @relation(fields: [shipmentZoneId], references: [id])
}

model BusinessHours {
  id        String   @id @default(cuid())
  dayOfWeek Int
  openTime  String
  closeTime String
  isOpen    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([dayOfWeek])
}

// ─── WhatsApp ─────────────────────────────────────────────────────────────────

model WhatsAppConversation {
  id        String   @id @default(cuid())
  phone     String   @unique
  waId      String
  state     String   @default("MENU")
  context   Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([phone])
}

model WhatsAppToken {
  id        String   @id @default(cuid())
  token     String   @unique
  phone     String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([token])
  @@index([phone])
  @@index([expiresAt])
}

// ─── Notifications ────────────────────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String?
  type      String
  title     String
  body      String
  read      Boolean  @default(false)
  data      Json?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([read])
  @@index([createdAt])
}

// ─── Audit ───────────────────────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  oldValues Json?
  newValues Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
}

// ─── Finance ─────────────────────────────────────────────────────────────────

enum FinanceTransactionType {
  INCOME
  EXPENSE
}

enum FinancePaymentMethod {
  EFECTIVO
  TRANSFERENCIA
  TARJETA
  // Egreso mixto: parte en efectivo (cashAmount) y el resto virtual.
  MIXTO
}

enum CashRegisterStatus {
  OPEN
  CLOSED
}

enum CashShift {
  MANANA
  NOCHE
}

enum EmployeeRole {
  COCINERO
  REPARTIDOR
  OTRO
}

model CashRegister {
  id             String             @id @default(cuid())
  status         CashRegisterStatus @default(OPEN)
  shift          CashShift?
  openingBalance Decimal            @db.Decimal(10, 2)
  expectedCash   Decimal?           @db.Decimal(10, 2)
  countedCash    Decimal?           @db.Decimal(10, 2)
  difference     Decimal?           @db.Decimal(10, 2)
  notes          String?
  openedById     String?
  closedById     String?
  openedAt       DateTime           @default(now())
  closedAt       DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  transactions FinanceTransaction[]

  @@index([status])
  @@index([openedAt])
}

model FinanceTransaction {
  id             String                 @id @default(cuid())
  cashRegisterId String?
  type           FinanceTransactionType
  amount         Decimal                @db.Decimal(10, 2)
  // Solo para paymentMethod = MIXTO: porción en efectivo (el resto es virtual).
  cashAmount     Decimal?               @db.Decimal(10, 2)
  category       String
  description    String?
  paymentMethod  FinancePaymentMethod
  orderId        String?
  employeeId     String?
  createdById    String?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  cashRegister CashRegister? @relation(fields: [cashRegisterId], references: [id])
  employee     Employee?     @relation(fields: [employeeId], references: [id])

  @@index([cashRegisterId])
  @@index([employeeId])
  @@index([type])
  @@index([createdAt])
}

model Employee {
  id            String       @id @default(cuid())
  firstName     String
  lastName      String
  phone         String?
  relativePhone String?
  address       String?
  role          EmployeeRole @default(OTRO)
  dailyWage     Decimal      @db.Decimal(10, 2)
  hireDate      DateTime
  active        Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  transactions   FinanceTransaction[]
  movements      EmployeeMovement[]
  deliveryOrders Order[]              @relation("OrderDeliveryEmployee")

  @@index([active])
  @@index([role])
}

enum EmployeeMovementKind {
  ADELANTO            // adelanto otorgado (suma al pendiente; normalmente desde Finanzas)
  ADELANTO_DESCUENTO  // descuento del adelanto (resta del pendiente, sin tocar caja)
  ACUMULADO_APORTE    // el empleado "guarda" sueldo (suma a favor)
  ACUMULADO_RETIRO    // retiro del acumulado a favor
}

model EmployeeMovement {
  id                   String               @id @default(cuid())
  employeeId           String
  kind                 EmployeeMovementKind
  amount               Decimal              @db.Decimal(10, 2)
  note                 String?
  financeTransactionId String?              @unique
  createdById          String?
  createdAt            DateTime             @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([kind])
  @@index([createdAt])
}
